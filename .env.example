# ContactGo — Variables de entorno
# Copia este archivo como .env.local y llena los valores

# ── SUPABASE ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROJECT-ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui

# ── PAYPAL ───────────────────────────────────────────────────
NEXT_PUBLIC_PAYPAL_CLIENT_ID=   # No se usa actualmente — PayPal deshabilitado

# ── APP ──────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://contactgo.net
NEXT_PUBLIC_WHATSAPP=18294728328
ADMIN_EMAIL  # Server-side only — NO usar NEXT_PUBLIC_=info@contactgo.net

# ── BANCO (BHD) ──────────────────────────────────────────────
NEXT_PUBLIC_BHD_TITULAR=         # Nombre del titular BHD
NEXT_PUBLIC_BHD_CUENTA=          # Número de cuenta BHD
NEXT_PUBLIC_BHD_IBAN=            # IBAN de la cuenta BHD

# ── EMAIL (Resend) ────────────────────────────────────────────
# Crear cuenta gratis en resend.com y obtener API key
# Verificar dominio: contactgo.net en Resend Dashboard
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM=ContactGo <pedidos@contactgo.net>

# ── AZUL (Banco Popular) ──────────────────────────────────────
AZUL_MERCHANT_ID=           # MerchantID asignado por AZUL
AZUL_MERCHANT_NAME=         # Nombre registrado en AZUL
AZUL_AUTH_KEY=              # Llave privada entregada por AZUL
AZUL_ENV=sandbox            # 'sandbox' | 'production'

# ── DGII ────────────────────────────────────────────────────
DGII_RNC=                   # RNC de la empresa ContactGo

# ── Notificaciones ──────────────────────────────────────────
ADMIN_EMAIL=                # Email interno para recibir pedidos (server-side)
CRON_SECRET=                # Secret para proteger endpoints de cron jobs

# ── WhatsApp (opcional) ─────────────────────────────────────
WHATSAPP_TOKEN=             # Token de Meta Business API (opcional)
WHATSAPP_PHONE_ID=          # Phone ID de Meta (opcional)
CALLMEBOT_API_KEY=          # API key de callmebot.com (alternativa gratuita)

# ── RATE LIMITING DISTRIBUIDO (Upstash Redis) ─────────────────
# Obtener gratis en: upstash.com → New Database → REST
# Sin esto, el rate limiting es in-memory (menos efectivo pero funcional)
UPSTASH_REDIS_REST_URL=    # https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=  # Token REST de Upstash
