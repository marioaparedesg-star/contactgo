async function getFeaturedProducts(): Promise<Product[]> {
  const sb = createServerSupabaseClient()
  const { data } = await sb.from('products')
    .select('*, categories(*)')
    .eq('activo', true)
    .gt('stock', 0)
    .order('stock', { ascending: false })
    .limit(8)
  return data ?? []
}

